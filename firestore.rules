rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Broker-created leads — only the owning broker can read/write
    match /brokerLeads/{leadId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.brokerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.brokerId;
    }

    // Invite tokens — broker can create; public read for invite link validation
    match /brokerLeadInvites/{token} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // OTP codes — server-side only via API routes (no client-side access needed)
    match /otpCodes/{email} {
      allow read, write: if false;
    }

    // Fact-find data — authenticated users can read/write their own doc
    match /leads/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
