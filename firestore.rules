rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Organisations — only the owner can read/write
    match /organisations/{orgId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // Broker profiles — each broker can read/write their own profile
    match /brokerProfiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Broker-created leads — only the owning broker can read/write
    match /brokerLeads/{leadId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.brokerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.brokerId;
    }

    // Invite tokens — broker can create/update; public read for invite link validation
    match /brokerLeadInvites/{token} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }

    // OTP codes — written and read by server-side API routes (client SDK, no auth context)
    match /otpCodes/{email} {
      allow read, write: if true;
    }

    // Fact-find data — authenticated users can read/write their own doc
    match /leads/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
