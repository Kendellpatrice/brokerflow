rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Organisations — only the owner can read/write
    match /organisations/{orgId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // Broker profiles — each broker can read/write their own profile
    match /brokerProfiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Activity log — broker can read their own entries; any authenticated user can create
    // (leads submit fact_find_submitted events on behalf of their broker)
    match /brokerActivity/{entryId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.brokerId;
      allow create: if request.auth != null;
    }

    // Broker-created leads — broker has full access; client can read/update their own
    match /brokerLeads/{leadId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.brokerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.brokerId;
      allow read, update: if request.auth != null && request.auth.uid == resource.data.email;
    }

    // Invite tokens — broker can create/update; validation is server-side only via Admin SDK
    match /brokerLeadInvites/{token} {
      allow read: if false;
      allow create, update: if request.auth != null;
    }

    // OTP codes — managed exclusively by server-side Admin SDK; no client access
    match /otpCodes/{email} {
      allow read, write: if false;
    }

    // OTP rate limit counters — managed exclusively by server-side Admin SDK
    match /otpRateLimit/{email} {
      allow read, write: if false;
    }

    // Fact-find data — authenticated users can read/write their own doc
    match /leads/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
